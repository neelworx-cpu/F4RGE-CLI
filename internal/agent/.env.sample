# ---------------------------------------------------------------------------
# 4RGED canonical client configuration (managed runtime)
# ---------------------------------------------------------------------------
# By default 4RGED routes ALL model calls through the F4RGE Gateway via
# platform-api using only your F4RGE session — no provider keys live on the
# client. These three values are all a managed client needs.

# F4RGE control-plane (platform-api) base URL.
F4RGE_PLATFORM_URL=http://localhost:3007
# F4RGE authenticator base URL (+ CLI sign-in path).
F4RGE_AUTH_URL=http://localhost:3003/cli

# ---------------------------------------------------------------------------
# Legacy provider auth (rollback only)
# ---------------------------------------------------------------------------
# Set F4RGE_CLI_ENABLE_LEGACY_PROVIDER_AUTH=1 to fall back to the pre-Gateway
# credential-lease / bring-your-own-key path. The provider keys below are ONLY
# read in that mode; leave them unset for the managed default.
# F4RGE_CLI_ENABLE_LEGACY_PROVIDER_AUTH=1
# F4RGED_ANTHROPIC_API_KEY=
# F4RGED_OPENAI_API_KEY=
# F4RGED_HYPER_API_KEY=
# F4RGED_OPENROUTER_API_KEY=
# F4RGED_ZAI_API_KEY=
